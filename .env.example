# Electroduction AI System — Environment Variables
# Copy this file to .env and fill in your keys
# NEVER commit .env to git

# ── Database paths ──────────────────────────────────────────────────────────
DB_ROOT_PATH=./data
LOG_LEVEL=INFO

# ── Finance APIs ─────────────────────────────────────────────────────────────
# FRED (Federal Reserve Economic Data) — free at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Alpha Vantage — free tier at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# ── Music APIs ───────────────────────────────────────────────────────────────
# Freesound — register at https://freesound.org/apiv2/apply/
FREESOUND_API_KEY=your_freesound_key_here

# ── Video APIs ───────────────────────────────────────────────────────────────
# YouTube Data API v3 — https://console.cloud.google.com/
YOUTUBE_API_KEY=your_youtube_api_key_here

# Pexels — https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_key_here

# ── HuggingFace (for model downloads and fine-tuning) ────────────────────────
# https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# ── OpenAI (for baseline comparison tests) ───────────────────────────────────
OPENAI_API_KEY=your_openai_key_here

# ── Anthropic (for baseline comparison tests) ────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── MCP Server ───────────────────────────────────────────────────────────────
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=8080
