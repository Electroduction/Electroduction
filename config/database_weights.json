  "weight_adjustments": {
    "safety_critical_boost": {
      "description": "Boost weight for safety-critical queries regardless of domain",
      "keywords": ["emergency", "life-threatening", "critical", "urgent", "safety", "hazard", "fatal"],
      "multiplier": 1.15,
      "max_weight": 1.0
    },
    "compliance_boost": {
      "description": "Boost weight for regulatory/code compliance queries",
      "keywords": ["code", "regulation", "compliance", "legal requirement", "standard", "OSHA", "NEC", "IPC", "GAAP"],
      "multiplier": 1.10,
      "max_weight": 1.0
    },
    "recency_decay": {
      "description": "Apply time decay to time-sensitive domains",
      "affected_domains": ["finance.macroeconomic_indicators", "video.platform_specs", "cybersecurity.cve_critical_catalog"],
      "decay_function": "exponential",
      "half_life_days": {
        "finance.macroeconomic_indicators": 90,
        "video.platform_specs": 120,
        "cybersecurity.cve_critical_catalog": 180
      }
    },
    "user_expertise_adjustment": {
      "description": "Adjust based on user expertise level (if known)",
      "novice": {"technical_domains_boost": 1.1, "explanation_detail": "high"},
      "intermediate": {"balanced": 1.0, "explanation_detail": "medium"},
      "expert": {"nuance_boost": 1.05, "explanation_detail": "low"}
    }
  },

  "algorithm_assignment": {
    "description": "Which algorithms to use for each domain category",
    "safety_critical": ["cot_verification"],
    "diagnostic_troubleshooting": ["anomaly_to_signature", "weak_to_strong"],
    "creative_generative": ["latent_interpolation", "pcg_logic_tables"],
    "procedural_rule_based": ["cot_verification", "weak_to_strong"],
    "financial_analytical": ["weak_to_strong"]
  },

  "query_routing_thresholds": {
    "single_domain_confidence": 0.80,
    "multi_domain_threshold": 0.60,
    "fallback_to_llm": 0.30,
    "verification_required": 0.90,
    "description": "Confidence thresholds for routing decisions; <fallback uses general LLM; >verification requires database source citation"
  }
